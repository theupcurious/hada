# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google OAuth (Calendar integration)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# LLM
# Supported providers: openrouter, minimax, anthropic, openai, gemini, kimi
LLM_PROVIDER=openrouter
LLM_API_KEY=
# Optional overrides (defaults come from the selected provider)
# LLM_MODEL=minimax/minimax-m2.7
# LLM_BASE_URL=https://openrouter.ai/api/v1

# Embeddings (optional — uses LLM_API_KEY by default)
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=
# EMBEDDING_MODEL=text-embedding-3-small

# Admin (optional — grants provider/model override in settings UI)
# ADMIN_USER_EMAILS=admin@example.com

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=HadaBot
TELEGRAM_WEBHOOK_SECRET=

# Web search (optional)
# Supported providers: tavily, brave, serpapi
SEARCH_PROVIDER=tavily
SEARCH_API_KEY=
# Provider-specific keys (only needed if SEARCH_API_KEY is not set)
# BRAVE_API_KEY=
# SERPAPI_API_KEY=
# TAVILY_API_KEY=

# Cron security (optional but recommended)
CRON_SECRET=
