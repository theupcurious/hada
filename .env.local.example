# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google OAuth (Calendar integration)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Default LLM provider
LLM_PROVIDER=minimax
# Optional shared fallback key used when a provider-specific key is not set
LLM_API_KEY=
# Optional: allow per-user provider/model overrides for specific admin emails only
# ADMIN_USER_EMAILS=admin@example.com,ops@example.com

# Provider API keys (configure at least one)
MINIMAX_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
KIMI_API_KEY=
MOONSHOT_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=HadaBot
TELEGRAM_WEBHOOK_SECRET=

# Search (optional)
SEARCH_PROVIDER=tavily
SEARCH_API_KEY=
# Supported values: tavily, brave, serpapi
# Optional provider-specific keys (if SEARCH_API_KEY is not set)
# BRAVE_API_KEY=
# BRAVE_SEARCH_API_KEY=
# SERPAPI_API_KEY=
# TAVILY_API_KEY=

# Cron security (optional but recommended)
CRON_SECRET=
