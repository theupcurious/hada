{
  "mcpServers": {
    "hada-calendar": {
      "command": "node",
      "args": ["/app/mcp-server/index.js"],
      "env": {
        "NEXT_APP_URL": "http://nextjs:3000",
        "OPENCLAW_API_TOKEN": "${OPENCLAW_API_TOKEN}"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "minimax/MiniMax-M2.1"
      }
    }
  },
  "models": {
    "providers": {
      "minimax": {
        "baseUrl": "https://api.minimax.io/v1",
        "api": "openai-completions",
        "models": [
          {
            "id": "MiniMax-M2.1",
            "name": "MiniMax M2.1",
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local"
  }
}
